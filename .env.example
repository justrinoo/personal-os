# Copy to .env and fill in your values.

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/personal_os"

# Better Auth — generate the secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET="replace-with-random-64-hex"
BETTER_AUTH_URL="http://localhost:3001"

# ClickUp integration — personal API token (ClickUp → Settings → Apps).
# Leave empty to disable sync; the UI will say the token is missing.
CLICKUP_TOKEN=""

# GitHub integration — fine-grained PAT, read-only (Contents + Pull requests).
# Optional for public repositories; required for private ones and for
# comfortable rate limits (5000/h vs 60/h).
GITHUB_TOKEN=""

# Coolify deployment webhook - shared secret checked on /api/webhooks/coolify
COOLIFY_WEBHOOK_SECRET=""

# Uptime Kuma - base URL + status page slug (create a status page in Kuma)
UPTIME_KUMA_URL=""
UPTIME_KUMA_STATUS_SLUG=""
