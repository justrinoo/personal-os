# Copy to .env and fill in your values.

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/personal_os"

# Better Auth — generate the secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET="replace-with-random-64-hex"
BETTER_AUTH_URL="http://localhost:3001"

# ClickUp integration — personal API token (ClickUp → Settings → Apps).
# Leave empty to disable sync; the UI will say the token is missing.
CLICKUP_TOKEN=""
